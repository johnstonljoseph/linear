//     BalanceAdjusted { id: UserId, delta: Money },
//     DecisionRecorded { request_id: RequestId, decision: Decision },
// }

fn add_event(mut events: Events, take event: Event) -> Events {
  mut events.push(take event)
}

fn decide(request: Request, user: User) -> Decision {
  if user.flags.is_locked {
    Decision.deny { reason: 1 }
  } else if user.flags.risk_score > 80 {
    Decision.review { queue: 2, priority: user.flags.risk_score }
  } else if request.body.amount.cents > user.balance.cents {
    Decision.deny { reason: 3 }
  } else {
    Decision.allow { reason: 0 }
  }
}

fn apply_decision(mut users: Users, request: Request, decision: Decision, mut events: Events) -> { users: Users, events: Events } {
  match decision {
    .allow { reason } => {
      let current = users.get(request.body.target)
      let next_balance = current.balance.add(request.body.amount)
      let next_user = User { id: current.id, org_id: current.org_id, balance: next_balance, flags: current.flags }
      let users1 = mut users.insert(current.id, take next_user)
      let event = Event.balance_adjusted { id: current.id, delta: request.body.amount }
      let events1 = add_event(mut events, take event)
      let { users: users2, events: events2 } = { users: users1, events: events1 }
      { users: users2, events: events2 }
    }
    .deny { reason } => {
      let event = Event.decision_recorded { request_id: request.id, decision: decision }
      let events1 = add_event(mut events, take event)
      { users: users, events: events1 }
    }
    .review { queue, priority } => {
      let event = Event.decision_recorded { request_id: request.id, decision: decision }
      add_event(mut events, take event)
      { users, events }
    }
  }
}

