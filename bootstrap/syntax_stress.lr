// Syntax stress test: Linear source beside roughly equivalent Rust.
//
// The Rust snippets are comments so this file remains parseable Linear.

type UserId = U32
type OrgId = U32
type Balance = U32
type Cents = U32
type UnixTime = U32
type RequestId = U32

struct Pair<T, U> { first: T, second: U }

enum Option<T> {
  none
  some(T)
}

struct Money { cents: Cents, currency: U32 }

struct User {
  id: UserId
  org_id: OrgId
  balance: Money
  flags: { is_admin: Bool, is_locked: Bool, risk_score: U32 }
}

struct Request {
  id: RequestId
  actor: UserId
  at: UnixTime
  body: { kind: U32, amount: Money, target: UserId }
}

enum Decision {
  allow { reason: U32 }
  deny { reason: U32 }
  review { queue: U32, priority: U32 }
}

enum Event {
  user_created { id: UserId, initial_balance: Money }
  balance_adjusted { id: UserId, delta: Money }
  decision_recorded { request_id: RequestId, decision: Decision }
}

type Users = HashMap<UserId, User>
type Events = Vector<Event>
type Decisions = HashMap<RequestId, Decision>

trait Eq {
  fn eq(self: Self, other: Self) -> Bool
}

impl Money {
  fn add(self, delta: Money) -> Money {
    Money { cents: self.cents + delta.cents, currency: self.currency }
  }
}

impl Eq for Money {
  fn eq(self, other: Money) -> Bool {
    self.cents == other.cents
  }
}

