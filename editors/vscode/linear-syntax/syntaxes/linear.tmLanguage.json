{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Linear",
  "scopeName": "source.linear",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#item-definitions" },
    { "include": "#functions" },
    { "include": "#methods-and-constructors" },
    { "include": "#variants" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#labels" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.linear",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.linear",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.linear",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "item-definitions": {
      "patterns": [
        {
          "name": "meta.type-alias.linear",
          "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.linear" },
            "2": { "name": "entity.name.type.alias.linear" }
          }
        },
        {
          "name": "meta.struct.linear",
          "match": "\\b(struct)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.struct.linear" },
            "2": { "name": "entity.name.type.struct.linear" }
          }
        },
        {
          "name": "meta.enum.linear",
          "match": "\\b(enum)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.enum.linear" },
            "2": { "name": "entity.name.type.enum.linear" }
          }
        },
        {
          "name": "meta.trait.linear",
          "match": "\\b(trait)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.trait.linear" },
            "2": { "name": "entity.name.type.trait.linear" }
          }
        },
        {
          "name": "meta.impl.linear",
          "match": "\\b(impl)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.impl.linear" }
          }
        },
        {
          "name": "meta.global.linear",
          "match": "\\b(global)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.global.linear" },
            "2": { "name": "variable.other.global.linear" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.linear",
          "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.linear" },
            "2": { "name": "entity.name.function.linear" }
          }
        },
        {
          "name": "support.function.call.linear",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "methods-and-constructors": {
      "patterns": [
        {
          "name": "meta.constructor.variant.linear",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\.([a-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.linear" },
            "2": { "name": "entity.name.function.constructor.linear" }
          }
        },
        {
          "name": "meta.method-call.linear",
          "match": "\\.([a-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.function.method.linear" }
          }
        }
      ]
    },
    "variants": {
      "patterns": [
        {
          "name": "entity.name.tag.variant.linear",
          "match": "\\.([a-z_][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.linear",
          "match": "\\b(if|else|match)\\b"
        },
        {
          "name": "keyword.other.linear",
          "match": "\\b(let|for|self|Self)\\b"
        },
        {
          "name": "storage.modifier.flow.linear",
          "match": "\\b(mut|take)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.linear",
          "match": "\\b(U8|U16|U32|U64|Bool|Symbol|Text|List|Vector|Vec|MutList|MutVector|MutVec|HashMap|MutHashMap|Option)\\b"
        },
        {
          "name": "entity.name.type.linear",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.linear",
          "match": "\\b(true|false|none)\\b"
        },
        {
          "name": "constant.language.unit.linear",
          "match": "\\(\\)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.linear",
          "match": "\\b\\d+(?:_\\d+)*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.linear",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.linear",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.assignment.linear",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.linear",
          "match": "\\+|-|\\*|/"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "variable.parameter.label.linear",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "variable.parameter.label.linear" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.linear",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.linear",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.linear",
          "match": "\\."
        },
        {
          "name": "punctuation.bracket.linear",
          "match": "[{}()\\[\\]]"
        }
      ]
    }
  }
}
